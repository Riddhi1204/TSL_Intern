# Frontend environment variables — copy to .env and fill in your values
# Never commit the actual .env file to source control

# Required: URL of your deployed backend (no trailing slash)
#
# IMPORTANT: Vite ONLY exposes environment variables prefixed with VITE_ to the browser.
# Plain variables (e.g. API_URL without the VITE_ prefix) are invisible at runtime.
#
# Local development:
VITE_API_URL=http://localhost:8000

# Production (update this after deploying to Render):
# VITE_API_URL=https://your-backend.onrender.com
