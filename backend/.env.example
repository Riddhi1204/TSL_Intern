# Backend environment variables — copy to .env and fill in your values
# Never commit the actual .env file to source control

# Required: Your OpenAI or Gemini API key
# Get OpenAI key at: https://platform.openai.com/api-keys
# Get free Gemini API key at: https://aistudio.google.com/
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Custom API Base URL (uncomment to use Google Gemini API for free)
# OPENAI_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai/

# Optional: Model to use (defaults to gpt-4o-mini). If using Gemini, set to gemini-1.5-flash or gemini-2.5-flash.
MODEL_NAME=gpt-4o-mini

# Required: Comma-separated list of allowed CORS origins
# Fix #9: Add your Vercel deployment URL here after deploying the frontend
# Example: https://my-app.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173,http://localhost:3000
