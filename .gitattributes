# Normalize line endings to LF on checkout (cross-platform consistency)
* text=auto eol=lf

# Force LF for these file types regardless of OS
*.py    text eol=lf
*.jsx   text eol=lf
*.js    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.env*  text eol=lf
